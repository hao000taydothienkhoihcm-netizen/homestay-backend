# ═══════════════════════════════════════
# HOMESTAY BACKEND CONFIG
# Copy file này thành .env và sửa các giá trị
# ═══════════════════════════════════════

# PostgreSQL — đổi password thành mật khẩu PostgreSQL của bạn
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@localhost:5432/homestay?schema=public"

# JWT Secret — bất kỳ chuỗi ngẫu nhiên dài
JWT_SECRET="change-this-to-a-random-string-32-chars-min"

# Server
PORT=3000
NODE_ENV=development

# CORS — frontend domain, dùng * cho dev
CORS_ORIGIN="*"
